# Normalize text files to LF in the repo regardless of host OS.
* text=auto eol=lf

# Source-like text — be explicit so encoding stays consistent
*.cs       text eol=lf
*.csproj   text eol=lf
*.sln      text eol=crlf
*.json     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.md       text eol=lf
*.hjson    text eol=lf
*.py       text eol=lf
*.ps1      text eol=crlf
*.sh       text eol=lf
*.svg      text eol=lf
*.txt      text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
LICENSE    text eol=lf

# Binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.ogg   binary
*.wav   binary
*.mp3   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.tmod  binary
*.dll   binary
*.pdb   binary
*.pdf   binary
*.ttf   binary
*.otf   binary
