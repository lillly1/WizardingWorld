			// === ACCESSORIES ===
			BasiliskFang: {
				DisplayName: 蛇怪毒牙
				Tooltip: "'致命的毒液，作为饰品更加致命'\n免疫中毒和剧毒"
			}
			InvisibilityCloak: {
				DisplayName: 隐形衣
				Tooltip:
					'''
					'佩弗利尔家族传下来的真正隐形衣'
					获得隐身效果并大幅降低敌人仇恨
					死亡圣器之一
					[c/AAAAAA:经由邓布利多的圣器指引重新取回]
					[c/AAAAAA:不是普通材料可制作的斗篷]
					'''
			}
			TimeTurner: {
				DisplayName: 时间转换器
				Tooltip:
					'''
					'时间的本质充满神秘'
					每10秒闪避一次致命攻击
					+10%移动速度
					'''
			}
			MaraudersMap: {
				DisplayName: 活点地图
				Tooltip:
					'''
					'我庄严宣誓我没干好事'
					在小地图上显示所有敌人
					获得危险感知
					减少秘密通道冷却时间
					[c/AAAAAA:由月亮脸、虫尾巴、大脚板和尖头叉子创造]
					'''
			}
			ResurrectionStone: {
				DisplayName: 复活石
				Tooltip:
					'''
					'第二件圣器，能召回逝者的石头'
					+6生命回复，+40最大生命值
					死亡圣器之一
					[c/AAAAAA:由冈特戒指净化后苏醒]
					[c/AAAAAA:需要邓布利多先剥离诅咒]
					'''
			}
			GauntsRing: {
				DisplayName: 冈特戒指
				Tooltip:
					'''
					'藏着复活石的受诅咒魂器戒指'
					+8%全部伤害，但诅咒不断啃噬你
					[c/FFD700:摧毁全部4个核心魂器后，把它带给邓布利多]
					'''
				Dynamic: {
					GauntCurse: "受诅咒的魂器——复活石就在其中"
					HorcruxProgress: "已摧毁魂器：{0}/4"
					AwakenedStatus: "[c/FFD700:戒指中的石头已被邓布利多唤醒]"
					PurifiableStatus: "[c/FFD700:把它带给邓布利多的画像以唤醒复活石]"
					LockedStatus: "[c/FF4444:摧毁全部魂器后才能净化这枚戒指]"
				}
			}
			BossCompass: {
				DisplayName: Boss进度指南针
				Tooltip:
					'''
					'它总是指向你的下一个伟大挑战'
					在提示中显示下一个要挑战的巫师Boss
					追踪你的完整Boss进度（已击败X/12）
					+3%伤害被动加成
					'''
				Dynamic: {
					NextChallenge: "[c/FFD700:下一个挑战：{0}]"
					ProgressTooltip: "[c/AAAAAA:{0}]"
					HorcruxTooltip: "[c/CC88FF:魂器狩猎：已摧毁{0}/4{1}]"
