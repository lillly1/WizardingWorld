					由奥利凡德出售。可重复使用
					'''
				Guide: {
					OverviewTitle: "=== 标准咒语书 ==="
					OverviewAuthor: "作者：米兰达·戈沙克"
					OverviewBrowse: "再次使用以浏览页面（共5页）："
					OverviewPage1: "  第1页：早期魔杖（Boss前）"
					OverviewPage2: "  第2页：中期魔杖（Boss后 / 困难模式）"
					OverviewPage3: "  第3页：后期魔杖（机械Boss后 / 终局）"
					OverviewPage4: "  第4页：功能咒语"
					Page1Title: "=== 第1页：早期魔杖 ==="
					Page1Line1: "橡木魔杖 [12伤害] — Stupefy（眩晕箭）"
					Page1Line2: "  配方：木材 + 坠星 @ 工作台"
					Page1Line3: "柳木魔杖 [16伤害] — Expelliarmus（击退箭）"
					Page1Line4: "  配方：木材 + 坠星 + 蓝宝石 @ 工作台"
					Page1Line5: "白蜡木魔杖 [22伤害] — Incendio（火焰箭）"
					Page1Line6: "  配方：白蜡木 + 狱石 + 红宝石 @ 附魔台"
					Page1Line7: "冬青木魔杖 [28伤害] — Expelliarmus + Protego护盾"
					Page1Line8: "红橡木魔杖 [32伤害] — Riddikulus（克制博格特 / 恐惧）"
					Page1Line9: "花楸木魔杖 [30伤害] — Bombarda（可破坏地形！）"
					Page1Line10: "桦木魔杖 [28伤害] — Levicorpus（将敌人抛向空中）"
					Page2Title: "=== 第2页：中期魔杖 ==="
					Page2Line1: "凤凰羽毛 [30伤害] — Incendio（有几率双发）"
					Page2Line2: "  需求：狱石锭 + 羽毛"
					Page2Line3: "龙心弦 [42伤害] — Sectumsempra（流血诅咒）"
					Page2Line4: "山楂木 [38伤害] — 连锁Stupefy（弹跳4个敌人）"
					Page2Line5: "黑刺李木 [35伤害] — Impedimenta（范围减速）"
					Page2Line6: "柏木 [30伤害] — Conjunctivitis（Boss减益工具）"
					Page2Line7: "独角兽毛 [55伤害] — Expecto Patronum（追踪守护者）"
					Page2Line8: "  需求：珍珠木 + 独角兽角 + 光明之魂"
					Page2Line9: "紫杉木 [48伤害] — Crucio（持续伤害光束）"
					Page3Title: "=== 第3页：后期与终局魔杖 ==="
					Page3Line1: "乌木魔杖 — Apparition（传送到光标处！）"
					Page3Line2: "  需求：乌木 + 光明/黑暗之魂 + 魔法精华"
					Page3Line3: "老魔杖 [120伤害] — Avada Kedavra（杀戮咒）"
					Page3Line4: "  掉落：伏地魔"
					Page3Line5: "厉火魔杖 [95伤害] — 不断蔓延的诅咒火焰"
					Page3Line6: "  需求：狱石 + 灵魂 + 日耀碎片 + 魔法精华"
					Page3Line7: "老魔杖精通已取代旧的命运魔杖路线"
					Page3Line8: "  通过魔杖精通掌控老魔杖，赢得其传奇称号"
					Page3Line9: "  “命运魔杖”如今只是传说文本，不再是独立物品"
					Page4Title: "=== 第4页：功能咒语 ==="
					Page4Line1: "落叶松魔杖 — 交替施放 Finite Incantatem（清除减益）与 Accio（拉取物品）"
					Page4Line2: "雪松魔杖 — Lumos Maxima（巨型光球，可伤害不死生物）"
					Page4Line3: "榆木魔杖 — Reparo（修复结界、Protego力场与房间增益）"
					Page4Tip1: "提示：附魔台也算工作台！"
					Page4Tip2: "提示：魔法精华会从所有魔法生物掉落！"
					Page4Tip3: "提示：Patronus 才是对付摄魂怪的真正答案。对付博格特请用 Riddikulus。"
				}
			}

