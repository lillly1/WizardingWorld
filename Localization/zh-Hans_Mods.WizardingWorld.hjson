		Items: {
			// === WANDS ===
			OakWand: {
				DisplayName: 橡木魔杖
				Tooltip: "'一根适合年轻巫师的坚实入门魔杖'\n施放昏昏倒地（昏迷咒）——命中时使敌人昏迷"
			}
			WillowWand: {
				DisplayName: 柳木魔杖
				Tooltip: "'柔韧而优雅'\n施放除你武器（缴械咒）——以强力击退缴械敌人"
			}
			AshWand: {
				DisplayName: 梣木魔杖
				Tooltip: "'忠于主人，绝不认他人'\n施放火焰熊熊（火焰咒）——点燃敌人的火焰弹"
			}
			PhoenixFeatherWand: {
				DisplayName: 凤凰羽毛魔杖
				Tooltip:
					'''
					'凤凰羽毛杖芯蕴含强大力量'
					施放火焰熊熊（火焰咒），25%几率发射双重火焰弹
					'''
			}
			DragonHeartstringWand: {
				DisplayName: 龙心弦魔杖
				Tooltip:
					'''
					'产生最强大的魔法，但容易出事故'
					施放神锋无影（神锋无影咒）——使敌人流血的黑魔法斩击诅咒
					'''
			}
			UnicornHairWand: {
				DisplayName: 独角兽毛发魔杖
				Tooltip:
					'''
					'稳定而忠诚，难以转向黑魔法'
					施放呼神护卫（守护神咒）——召唤一个追踪银色守护者
					'''
			}
			ElderWand: {
				DisplayName: 接骨木魔杖
				Tooltip:
					'''
					'死亡之杖。命运之杖。'
					施放阿瓦达索命（杀戮咒）——不可饶恕咒
					瞬间击杀生命值低于15%的非Boss敌人
					法力越低，伤害越高
					'''
			}
			AlderWand: {
				DisplayName: 赤杨木魔杖
				Tooltip: "'赤杨木虽不屈不挠，但它的理想主人是乐于助人且体贴的'\n施放昏昏倒地（昏迷咒）——比橡木魔杖更快更强\n简单的前期升级——无需宝石"
			}
			SwordOfGryffindor: {
				DisplayName: 格兰芬多之剑
				Tooltip:
					'''
