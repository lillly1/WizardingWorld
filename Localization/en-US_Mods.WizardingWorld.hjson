			}

			AquaFortisBuff: {
				DisplayName: Aqua Fortis
				Description: Water warrior — gills, water immunity, massive underwater combat bonuses
			}

			SeekersReflexesBuff: {
				DisplayName: Seeker's Reflexes
				Description: Lightning-fast reflexes — speed, dodge, and attack speed boosted
			}

			BabyDragonBuff: {
				DisplayName: Baby Horntail
				Description: A baby Hungarian Horntail lights your way with dragonfire
			}

			ResurrectionBuff: {
				DisplayName: Resurrection
				Description: One death prevented — you will rise from the ashes instead of dying
			}

			ShieldCharmBuff: {
				DisplayName: Shield Charm
				Description: Protego — +10 defense, +8% damage reduction
			}

			FenrirsWolfsbaneBuff: {
				DisplayName: Fenrir's Wolfsbane
				Description: Alpha werewolf power — massive melee and speed bonuses at night
			}

			StealthDraughtBuff: {
				DisplayName: Stealth Draught
				Description: Invisible, greatly reduced aggro, speed boosted -- hiding in plain sight
			}

			WardOfHopeBuff: {
				DisplayName: Ward of Hope
				Description: A silver ward against despair -- +4 defense, +2 life regen, calming light
			}

			RoomRecoveryBuff: {
				DisplayName: Room of Recovery
				Description: The Room provides healing -- +12 life regen, +15 defense, +10% damage reduction
			}

			RoomTrainingBuff: {
				DisplayName: Room of Practice
				Description: The Room provides a training ground -- +20% spell damage, +10 spell crit, +40 max mana
			}

			RoomVaultBuff: {
				DisplayName: Come and Go Room
				Description: The Room reveals hidden treasure -- increased luck, treasure sense, coin attraction
			}

			RoomSanctuaryBuff: {
				DisplayName: Room of Sanctuary
				Description: The Room provides shelter -- +8 defense, +4 life regen, mana regen, +5% damage reduction
			}

			RoomRestorationBuff: {
				DisplayName: Room of Restoration
				Description: The Room soothes despair -- relieves dark aftereffects, +6 defense, +6 life regen, ward extension
			}

			RoomResistanceBuff: {
				DisplayName: Resistance Headquarters
				Description: The Room becomes a resistance headquarters -- +10 defense, +8% endurance, +6 life regen, Jinxed/DarkCurse immunity
			}

			DAMeetingBuff: {
				DisplayName: D.A. Meeting
				Description: Dumbledore's Army rallies together. +5% damage, +4 defense, danger sense, +3 life regen.
			}

			ResistanceResolveBuff: {
				DisplayName: Resistance Resolve
				Description: The wards hold because of you. +8 defense, +6% endurance, Jinxed immunity, +4 life regen, +5% luck.
			}

			GryffindorFeastBuff: {
				DisplayName: Gryffindor Feast Blessing
				Description: Courage fills your heart -- +12% damage, +8 defense, +2 life regen
			}

			SlytherinFeastBuff: {
				DisplayName: Slytherin Feast Blessing
				Description: Ambition sharpens your mind -- +10% crit, +8% speed
			}

			RavenclawFeastBuff: {
				DisplayName: Ravenclaw Feast Blessing
				Description: Wisdom guides your spells -- +15% spell damage, +60 max mana, enhanced mana regen
			}

			HufflepuffFeastBuff: {
				DisplayName: Hufflepuff Feast Blessing
				Description: Loyalty strengthens your resolve -- +10 defense, +6 life regen, +8% damage reduction
			}

			QuidditchCupBuff: {
				DisplayName: Quidditch Cup Victory
				Description: Your house won the Quidditch Cup! +10% damage, +10% speed, +luck
			}

			TriwizardChampionBuff: {
				DisplayName: Triwizard Champion
				Description: Eternal glory! +15% damage, +10% speed, enhanced luck
			}

			OrderCommendationBuff: {
				DisplayName: Order Commendation
				Description: The Order recognizes your service -- +10% spell damage, +4 defense, +3 life regen
			}

			TemporalInsightBuff: {
				DisplayName: Temporal Insight
				Description: Time flows clearly -- +8% damage, +5% speed, danger sense
			}

			VeilWardBuff: {
				DisplayName: Veil Ward
				Description: The Veil's pull cannot reach you -- +8 defense, +6% endurance, darkness immunity, despair resistance
			}

			VaultFortuneBuff: {
				DisplayName: Vault Fortune
				Description: Gringotts rewards the diligent -- +luck, coin attraction, +5% damage
			}

			ShoppingDayBuff: {
				DisplayName: Shopping Day
				Description: Diagon Alley commerce! Reduced shop prices, +luck, treasure sense, coin attraction
			}

			DarkAppraiserBuff: {
				DisplayName: Dark Appraiser
				Description: Eyes sharpened by dark knowledge -- night vision, +6% damage, danger sense
			}

			MoonwardBuff: {
				DisplayName: Moonward Protection
				Description: The Shack's wards hold -- +6 defense, +4 life regen, Darkness/Jinxed immunity, +5% speed
			}

			CastleVictoryBuff: {
				DisplayName: Castle Victory
				Description: Hogwarts stands! +12% all damage, +10 defense, +6 life regen, +0.1 luck.
			}

			CastleDefenseBuff: {
				DisplayName: Castle Defenders
				Description: Animated armor and stone guardians fight alongside you. +8 defense.
			}
		}

