	BossCompass: {
		DisplayName: Boss Progression Compass
		Tooltip:
			'''
			'It always points to your next great challenge'
			Shows the next wizard boss in the tooltip
			Tracks boss and Horcrux progress
			+3% damage
			'''

		Dynamic: {
			NextChallenge: "[c/FFD700:Next challenge: {0}]"
			ProgressTooltip: "[c/AAAAAA:{0}]"
			HorcruxTooltip: "[c/CC88FF:Horcrux Hunt: {0}/4 destroyed{1}]"
			NaginiSuffix: ", Nagini defeated"
			NextTroll: Mountain Troll (use a Smelly Sock)
			NextQuirrell: Professor Quirrell (use a Suspicious Turban after Troll + Eye of Cthulhu)
			NextBasilisk: Basilisk (use a Serpent's Diary after Quirrell + Skeletron)
			NextAragog: Aragog (use an Acromantula Egg in Hardmode)
			NextFluffy: Fluffy (use an Enchanted Flute after a mechanical boss)
			NextHorntail: Hungarian Horntail (use a Dragon Egg)
			NextUmbridge: Dolores Umbridge (use an Educational Decree)
			NextFenrir: Fenrir Greyback (use a Bloodied Claw during a Blood Moon)
			NextBellatrix: Bellatrix Lestrange (use a Prisoner Tag after Fenrir and Plantera)
			NextBartyCrouch: Barty Crouch Jr (use a Suspicious Flask after Bellatrix and Plantera)
			NextDementorKing: Azkaban's Despair (use a Frozen Soul Lantern after Barty and Golem, at night)
			NextVoldemortReady: Lord Voldemort (use a Dark Mark at night after Cultist; weakened by the Horcrux Hunt)
			NextVoldemortBlocked: Destroy more Horcruxes before facing Lord Voldemort
			NextPurifyRing: Bring Gaunt's Ring to Dumbledore
			NextClaimCloak: Ask Dumbledore about the true Invisibility Cloak
			NextUniteHallows: Unite the Hallows to complete the hidden ending route
			Completed: All wizard objectives are complete. You are the Master of Death.
			ProgressSummary: Wizard bosses defeated: {0}/12
		}
	}

