			PatronusCharmBuff: {
				DisplayName: Patronus Guardian
				Description: A silver guardian protects you (+10 defense, +2 life regen)
			}

			PepperupBuff: {
				DisplayName: Peppered Up
				Description: Energized! Speed and attack speed boosted, fire/cold immune, steam from ears
			}

			SkeleGroBuff: {
				DisplayName: Regrowing Bones
