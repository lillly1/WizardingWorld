Mods: {
	WizardingWorld: {
		DamageClasses: {
			SpellDamage.DisplayName: spell
		}

		Conditions: {
			DownedBasilisk: After defeating the Basilisk
			DownedHorntail: After defeating the Hungarian Horntail
			DownedVoldemort: After defeating the Dark Lord
			DownedTroll: After defeating the Mountain Troll
			DownedAragog: After defeating Aragog
			DownedFluffy: After defeating Fluffy
			DownedBellatrix: After defeating Bellatrix Lestrange
			DownedFenrir: After defeating Fenrir Greyback
			DownedDementorKing: After defeating Azkaban's Despair
			DownedQuirrell: After defeating Professor Quirrell
			DownedUmbridge: After defeating Dolores Umbridge
			DownedBartyCrouch: After defeating Barty Crouch Jr
		}

		Items: {
			// === WANDS ===
			OakWand: {
				DisplayName: Oak Wand
				Tooltip: "'A sturdy first wand for any young witch or wizard'\nCasts Stupefy — stuns enemies on hit"
			}
			WillowWand: {
				DisplayName: Willow Wand
				Tooltip: "'Flexible and elegant'\nCasts Expelliarmus — disarms with powerful knockback"
			}
			AshWand: {
				DisplayName: Ash Wand
				Tooltip: "'Loyal to its owner, never to another'\nCasts Incendio — fire bolt that ignites enemies"
			}
			PhoenixFeatherWand: {
				DisplayName: Phoenix Feather Wand
				Tooltip:
					'''
					'The phoenix feather core provides great power'
					Casts Incendio with a 25% chance for a double shot
					'''
			}
			DragonHeartstringWand: {
				DisplayName: Dragon Heartstring Wand
				Tooltip:
					'''
					'Produces the most powerful magic, prone to accidents'
					Casts Sectumsempra — dark slashing curse that bleeds enemies
					'''
			}
			UnicornHairWand: {
				DisplayName: Unicorn Hair Wand
				Tooltip:
					'''
					'Consistent and faithful, difficult to turn to the Dark Arts'
					Casts Expecto Patronum — summons a homing silver guardian
					'''
			}
			ElderWand: {
				DisplayName: Elder Wand
				Tooltip:
					'''
					'The Deathstick. The Wand of Destiny. The Elder Wand.'
					Casts Avada Kedavra — the Killing Curse
					Instantly kills non-boss enemies below 15% HP
					[c/FF3333:WARNING: Each cast builds Dark Arts Corruption]
					[c/FF3333:Corruption weakens your Patronus and causes paranoia]
					[c/AAAAAA:The singular Deathly Hallow — one of a kind]
					'''
			}
			AlderWand: {
				DisplayName: Alder Wand
				Tooltip: "'Alder is an unyielding wood, yet its ideal owner is helpful and considerate'\nCasts Stupefy — faster and stronger than Oak Wand\nEasy early-game upgrade — no gems required"
			}
			SwordOfGryffindor: {
				DisplayName: Sword of Gryffindor
				Tooltip:
					'''
					'Goblin-made, it imbibes that which makes it stronger'
					Imbued with Basilisk venom
					'''
			}
			NimbusBroomstick: {
				DisplayName: Nimbus 2000
				Tooltip: "'The fastest broomstick in the world!'\nSummons a flying broomstick mount"
			}

			// === ARMOR ===
			GryffindorHood: {
				DisplayName: Gryffindor Hood
				Tooltip: "+8% spell damage"
				SetBonus: "Bravery: +15% damage, +10% melee speed"
			}
			GryffindorRobes: {
				DisplayName: Gryffindor Robes
				Tooltip: "+5% spell damage, +20 max life"
			}
			GryffindorLeggings: {
				DisplayName: Gryffindor Leggings
				Tooltip: "+10% movement speed"
			}
			SlytherinHood: {
				DisplayName: Slytherin Hood
				Tooltip: "+8% spell crit chance"
				SetBonus: "Cunning: +12% crit chance"
			}
			SlytherinRobes: {
				DisplayName: Slytherin Robes
				Tooltip: "+8% spell damage, +4% crit chance"
			}
			SlytherinLeggings: {
				DisplayName: Slytherin Leggings
				Tooltip: "+8% movement speed, reduced enemy aggro"
			}
			RavenclawHood: {
				DisplayName: Ravenclaw Hood
				Tooltip: "+20 max mana"
				SetBonus: "Wisdom: +20% spell damage, +40 max mana, mana regeneration"
			}
			RavenclawRobes: {
				DisplayName: Ravenclaw Robes
				Tooltip: "+10% spell damage, +20 max mana, -10% mana cost"
			}
			RavenclawLeggings: {
				DisplayName: Ravenclaw Leggings
				Tooltip: "+6% movement speed, mana regen +3"
			}
			HufflepuffHood: {
				DisplayName: Hufflepuff Hood
				Tooltip: "+3 defense, +1 life regen"
				SetBonus: "Loyalty: +8 defense, +4 life regen, 30% thorns damage"
			}
			HufflepuffRobes: {
				DisplayName: Hufflepuff Robes
				Tooltip: "+40 max life, +2 life regen"
			}
			HufflepuffLeggings: {
				DisplayName: Hufflepuff Leggings
				Tooltip: "+5% movement speed, +2 defense"
			}
			DarkWizardHood: {
				DisplayName: Dark Wizard Hood
				Tooltip: "+12% spell damage, +30 max mana"
				SetBonus: "Dark Arts: +25% spell damage, +15% spell crit"
			}
			DarkWizardRobes: {
				DisplayName: Dark Wizard Robes
				Tooltip: "+10% spell damage, +40 max mana, -15% mana cost"
			}
			DarkWizardLeggings: {
				DisplayName: Dark Wizard Leggings
				Tooltip: "+12% movement speed, mana regen +5"
			}

			// === ACCESSORIES ===
			BasiliskFang: {
				DisplayName: Basilisk Fang
				Tooltip: "'Deadly venom, even deadlier as an accessory'\nImmunity to Poison and Venom"
			}
			InvisibilityCloak: {
				DisplayName: Invisibility Cloak
				Tooltip:
					'''
					'The true Cloak of Invisibility, handed down through the Peverell line'
					Grants invisibility and greatly reduced enemy aggro
					Part of the Deathly Hallows
					[c/AAAAAA:A unique relic reclaimed through Dumbledore's Hallows guidance]
					[c/AAAAAA:Not craftable from ordinary materials]
					'''
			}
			DemiguiseCloak: {
				DisplayName: Demiguise Weave Cloak
				Tooltip:
					'''
					'Woven from Demiguise hair — excellent stealth work, but not the Hallow'
					Grants invisibility, reduced aggro, and +5% movement speed
					[c/AAAAAA:Ordinary wizarding gear inspired by Demiguise pelts]
					'''
			}
			TimeTurner: {
				DisplayName: Time Turner
				Tooltip:
					'''
					'Mysterious is the nature of time'
					Dodge one lethal hit every 10 seconds
					+10% movement speed
					'''
			}
			MaraudersMap: {
				DisplayName: Marauder's Map
				Tooltip:
					'''
					'I solemnly swear that I am up to no good'
					Reveals all enemies on the minimap
					Grants danger sense
					Reduces Secret Passage cooldown
					[c/AAAAAA:Created by Moony, Wormtail, Padfoot, and Prongs]
					'''
			}
			ResurrectionStone: {
				DisplayName: Resurrection Stone
				Tooltip:
					'''
					'The second Hallow, the stone that recalls the dead'
					+6 life regen, +40 max life
					Part of the Deathly Hallows
					[c/AAAAAA:Awakened from Gaunt's Ring after the Horcrux Hunt]
					[c/AAAAAA:Dumbledore must strip away the curse first]
					'''
			}
			GauntsRing: {
				DisplayName: Gaunt's Ring
				Tooltip:
					'''
					'A cursed Horcrux ring hiding the Resurrection Stone'
					+8% all damage, but the curse gnaws at you
					[c/FFD700:Destroy all 4 core Horcruxes, then bring it to Dumbledore]
					'''
				Dynamic: {
					GauntCurse: "A cursed Horcrux — the Resurrection Stone lies within"
					HorcruxProgress: "Horcruxes destroyed: {0}/4"
					AwakenedStatus: "[c/FFD700:The stone within has already been awakened by Dumbledore]"
					PurifiableStatus: "[c/FFD700:Take this to Dumbledore's portrait to awaken the Stone]"
					LockedStatus: "[c/FF4444:Destroy all Horcruxes to purify this ring]"
				}
			}
			AzkabanWardensKey: {
				DisplayName: Azkaban Warden's Key
				Tooltip:
					'''
					'An old ward-key from the prison fortress'
					+6 defense, +5% endurance
					Resists despair, Darkness, and Dark Curse
					Empowers you while a Patronus is active
					'''
			}
			BossCompass: {
				DisplayName: Boss Progression Compass
				Tooltip:
					'''
					'It always points to your next great challenge'
					Shows which wizard boss to fight next in the tooltip
					Tracks boss progression, Horcrux Hunt progress, and Hallows guidance
					+3% damage passive bonus
					'''
				Dynamic: {
					NextChallenge: "[c/FFD700:Next Challenge: {0}]"
					ProgressTooltip: "[c/AAAAAA:{0}]"
					HorcruxTooltip: "[c/CC88FF:Horcrux Hunt: {0}/4 destroyed{1}]"
					NaginiSuffix: ", Nagini fallen"
					NextTroll: "Mountain Troll (use Smelly Sock)"
					NextQuirrell: "Professor Quirrell (use Suspicious Turban)"
					NextBasilisk: "Basilisk (use Serpent's Diary)"
					NextAragog: "Aragog (use Acromantula Egg — Hardmode)"
					NextFluffy: "Fluffy (use Enchanted Flute — post-Mech)"
					NextHorntail: "Hungarian Horntail (use Dragon Egg)"
					NextUmbridge: "Dolores Umbridge (use Educational Decree)"
					NextFenrir: "Fenrir Greyback (use Bloodied Claw — Blood Moon)"
					NextBellatrix: "Bellatrix Lestrange (use Prisoner Tag — post-Plantera)"
					NextBartyCrouch: "Barty Crouch Jr (use Suspicious Flask)"
					NextDementorKing: "Dementor King (use Frozen Soul Lantern — post-Golem)"
					NextVoldemortReady: "Lord Voldemort (use Dark Mark — post-Cultist, weakened by the Hunt)"
					NextVoldemortBlocked: "Destroy more Horcruxes before facing Lord Voldemort"
					NextPurifyRing: "Take Gaunt's Ring to Dumbledore"
					NextClaimCloak: "Speak to Dumbledore about the true Invisibility Cloak"
					NextUniteHallows: "Unite the Hallows to complete the hidden ending path"
					Completed: "All wizard goals completed. Master of Death achieved."
					ProgressSummary: "Wizard Bosses: {0}/12 defeated"
				}
			}

			// === CONSUMABLES ===
			EnchantingTableItem: {
				DisplayName: Enchanting Table
				Tooltip: "'Where magic takes form'\nUsed to craft wands, potions, and magical equipment"
			}
			BasiliskSummonItem: {
				DisplayName: Serpent's Diary
				Tooltip: "'Open at your own peril'\nSummons the Basilisk"
			}
			HorntailSummonItem: {
				DisplayName: Cracked Dragon Egg
				Tooltip: "'It's hatching!'\nSummons the Hungarian Horntail"
			}
			VoldemortSummonItem: {
				DisplayName: Dark Mark
				Tooltip: "'He Who Must Not Be Named returns'\nSummons Lord Voldemort — the TRUE final boss\nRequires post-Lunatic Cultist. Night only.\n[c/FFD700:Destroy Horcruxes first to weaken him!]"
			}
			DragonScale: {
				DisplayName: Dragon Scale
				Tooltip: "'Still warm to the touch'\nCrafting material"
			}
			GoldenEgg: {
				DisplayName: Golden Egg
				Tooltip: "'Contains a clue... and something more'\nRare crafting material"
			}
			LakeRescueToken: {
				DisplayName: Lake Rescue Token
				Tooltip: "'A glowing token from the lake bed'\nCollect 3 during the Great Lake Trial"
			}
			ChampionsTrophy: {
				DisplayName: Triwizard Cup
				Tooltip:
					'''
					'Eternal glory awaits the champion!'
					The actual grand prize of the Triwizard Tournament
					Awarded for completing all three tasks
					+12% all damage, +8% crit, +6 defense, +4 life regen
					'''
			}

			WizardsAlmanac: {
				DisplayName: Wizard's Almanac
				Tooltip:
					'''
					'The complete encyclopedia of the Wizarding World'
					10 pages covering EVERY system in the mod
					Bosses, armor, accessories, potions, mounts, pets, crafting, systems, tips
					Use repeatedly to browse pages
					Sold by Dumbledore. Crafted from Spell Book + Books + Essence
					'''
			}

			// === POTIONS ===
			Butterbeer: {
				DisplayName: Butterbeer
				Tooltip: "'A warm drink from the Three Broomsticks'\nGrants Well Fed, +2 regen, +2 defense"
			}
			FelixFelicis: {
				DisplayName: Felix Felicis
				Tooltip: "'Liquid Luck'\nGreatly increases luck, +10% crit chance, increased coin drops"
			}
			PolyjuicePotion: {
				DisplayName: Polyjuice Potion
				Tooltip: "'Tastes like goblin p-'\nGrants invisibility and reduced aggro"
			}
			WolfsbanePotion: {
				DisplayName: Wolfsbane Potion
				Tooltip: "'Keeps the wolf at bay... mostly'\nGrants werewolf power boost, stronger at night"
			}

			// === PET ===
			GoldenSnitchItem: {
				DisplayName: Golden Snitch
				Tooltip: "'I open at the close'\nSummons a Golden Snitch pet"
			}

			// === WEAPON UPGRADES ===
			InfernalPhoenixWand: {
				DisplayName: Infernal Phoenix Wand
				Tooltip:
					'''
					'The phoenix feather, tempered by dragonfire'
					Upgraded Phoenix Feather Wand — fires 5-bolt Incendio spread
					Crafted from Phoenix Feather Wand + Dragon Scale
					'''
			}
			VenomousSwordOfGryffindor: {
				DisplayName: Venomous Sword of Gryffindor
				Tooltip:
					'''
					'It imbibes that which makes it stronger — now with spider venom'
					Upgraded Sword of Gryffindor — AoE poison cloud + lifesteal
					Triple venom: Basilisk + Spider + Jinxed on every hit
					Crafted from Sword of Gryffindor + Spider Silk + Basilisk Fang
					'''
			}
			ShadowElderWand: {
				DisplayName: Legacy Shadow Elder Wand
				Tooltip:
					'''
					[Legacy item]
					Automatically converts to the Elder Wand in old saves
					The separate shadow upgrade path has been retired
					'''
			}

			// === DUMBLEDORE'S ARMY ===
			DAGalleon: {
				DisplayName: D.A. Galleon
				Tooltip: "'The coin burns when Dumbledore's Army is called to gather'\nActivates a D.A. Meeting coordination buff (8 min)\nAlso serves as DA membership token for the Room of Requirement"
			}
			CastleWardThread: {
				DisplayName: Castle Ward Thread
				Tooltip: "Residual enchantment thread from stabilized castle wards\nCrafting material"
			}
			DefendersSignet: {
				DisplayName: Defender's Signet
				Tooltip:
					'''
					'Earned by those who stood when the wards were falling'
					+6 defense, +5% endurance
					Immunity to Jinxed and Confused
					+5% movement speed
					'''
			}

			// === ST MUNGO'S ===
			StMungosPass: {
				DisplayName: St Mungo's Visitor Pass
				Tooltip: "'Purge and Dowse, Ltd. -- please state your purpose'\nUnlocks St Mungo's Hospital after the Horntail\nUse again to start triage missions"
			}
			HealersSalts: {
				DisplayName: Healer's Salts
				Tooltip: "Purified remedy residue from St Mungo's triage wards\nCrafting material"
			}
			HealersSatchel: {
				DisplayName: Healer's Satchel
				Tooltip:
					'''
					'Standard issue for Healers on ward rotation'
					+6 life regen, +5% endurance
					Immunity to Venom and Confused
					Reduced potion cooldown
					Passive despair relief
					'''
			}

			// === BATTLE OF HOGWARTS ===
			HorcruxTracker: {
				DisplayName: Horcrux Tracker
				Tooltip: "'Dumbledore's wartime intelligence'\nShows Horcrux Hunt progress and battle readiness\nUse to unlock or start the Battle of Hogwarts\nReusable"
			}
			CastleDefenseRune: {
				DisplayName: Castle Defense Rune
				Tooltip: "Residual ward energy from the Battle of Hogwarts\nCrafting material"
			}
			ProtectorsBadge: {
				DisplayName: Protector's Badge
				Tooltip:
					'''
					'Awarded to those who defended Hogwarts when it mattered most'
					+8 defense, +6% endurance
					Immunity to Jinxed and Dark Curse
					+4 life regen
					Passive despair relief
					'''
			}
		}

