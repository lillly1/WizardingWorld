					'''
			}
			ShieldHat: {
				DisplayName: Shield Hat
				Tooltip: "'Weasleys' Wizard Wheezes — Shield Line'\n+3 defense, +3% spell damage\nEnchanted with protective charms"
			}
			DecoyDetonator: {
				DisplayName: Decoy Detonator
				Tooltip: "'Weasleys' Wizard Wheezes — Defense Line'\nDraws enemy aggro, then explodes dealing damage + Jinxed debuff\nBrilliant tactical diversion"
			}
			PrefectBadge: {
