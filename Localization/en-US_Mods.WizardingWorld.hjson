				DisplayName: Liquid Luck
				Description: Everything seems to go your way
			}
			PolyjuiceBuff: {
				DisplayName: Polyjuice Disguise
				Description: You look like someone else entirely
			}
			WolfsbaneBuff: {
				DisplayName: Wolfsbane
