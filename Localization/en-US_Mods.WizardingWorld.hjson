			ExtendableEars: {
				DisplayName: Extendable Ears
				Tooltip: "'Weasleys' Wizard Wheezes — hear everything'\nGrants enemy detection, danger sense, and wire vision"
			}
			PeruvianDarknessPowder: {
				DisplayName: Peruvian Instant Darkness Powder
