			WizardBoots: {
				DisplayName: Wizard Boots
				Tooltip: Vanity item
			}
			CedarWand: {
				DisplayName: Cedar Wand
				Tooltip: "'Those who are well-matched with cedar carry the potential to be a frightening adversary'\nCasts Lumos Maxima — massive light orb that damages undead"
