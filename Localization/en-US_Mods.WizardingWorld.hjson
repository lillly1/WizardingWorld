		// === PHASE 2 ITEMS ===
		Items: {
			HollyWand: {
				DisplayName: Holly Wand
				Tooltip: "'The brother wand to the Dark Lord's'\nCasts Expelliarmus with periodic Protego shield"
			}
			VineWand: {
				DisplayName: Vine Wand
				Tooltip: "'Ten and three-quarter inches, dragon heartstring core'\nAlternates Wingardium Leviosa and Aguamenti"
			}
			YewWand: {
				DisplayName: Yew Wand
				Tooltip: "'Thirteen and a half inches, phoenix feather core'\nCasts Crucio (channeled) with chance for Reducto explosions"
			}
			BeatersBat: {
				DisplayName: Beater's Bat
				Tooltip: "'Standard Quidditch equipment — for Bludgers, not people'\nMassive knockback, launches enemies upward"
			}
			Quaffle: {
				DisplayName: Quaffle
				Tooltip: "'The ball that scores points in Quidditch'\nBounces off walls and returns to you"
			}
			FireboltBroomstick: {
				DisplayName: Firebolt
				Tooltip: "'The finest racing broom in existence'\nUpgraded flying broomstick mount — faster than Nimbus 2000"
			}
			HippogriffFeather: {
				DisplayName: Hippogriff Feather
				Tooltip: "'You must bow and wait. Always let a Hippogriff make the first move.'\nSummons a Hippogriff mount"
			}
			PhoenixFeatherStaff: {
				DisplayName: Phoenix Feather Staff
				Tooltip: "'Fawkes has given you a most faithful companion'\nSummons a Phoenix minion that attacks and heals"
			}
			NifflerItem: {
				DisplayName: Niffler Pouch
				Tooltip: "'They go after anything shiny'\nSummons a coin-finding Niffler pet"
			}
			RiddlesDiary: {
				DisplayName: Riddle's Diary
				Tooltip: "'The first Horcrux'\n+18% spell damage, +8% spell crit\n[c/FF3333:HORCRUX: Drains life, builds Dark Arts Corruption]\n[c/FF3333:Causes paranoia. Weakens your Patronus.]\n[c/FFD700:Can be destroyed at the Enchanting Table to weaken Voldemort]"
			}
			SlytherinsLocket: {
				DisplayName: Slytherin's Locket
				Tooltip: "'None could open the locket but a Parselmouth'\n+12 defense, +8% damage reduction, poison immunity\n[c/FF3333:HORCRUX: Builds Dark Arts Corruption over time]\n[c/FF3333:Breeds distrust and aggression. Weakens Patronus.]\n[c/FFD700:Can be destroyed at the Enchanting Table to weaken Voldemort]"
			}
			HufflepuffsCup: {
				DisplayName: Hufflepuff's Cup
				Tooltip: "'A small golden cup with two finely wrought handles'\n+8 life regen, +60 max life, faster potion recovery\n[c/FF3333:HORCRUX: Builds Dark Arts Corruption over time]\n[c/FF3333:Drains vitality. Reduces vision.]\n[c/FFD700:Can be destroyed at the Enchanting Table to weaken Voldemort]"
			}
			DiademOfRavenclaw: {
				DisplayName: Diadem of Ravenclaw
				Tooltip: "'Wit beyond measure is man's greatest treasure'\n+80 max mana, +15% spell damage, -15% mana cost\n[c/FF3333:HORCRUX: Builds Dark Arts Corruption over time]\n[c/FF3333:Clouds judgment. Drains mana. Reduces max life.]\n[c/FFD700:Can be destroyed at the Enchanting Table to weaken Voldemort]"
			}
			SortingHat: {
				DisplayName: Sorting Hat
				Tooltip: "'Oh you may not think I'm pretty, but don't judge on what you see'\nBoosts the set bonus of any Hogwarts house armor worn\nSmall generic bonus without house armor"
			}
			FiendfyreWand: {
				DisplayName: Fiendfyre Wand
				Tooltip: "'I would never, ever have dared use it — it was too dangerous' — Hermione\nFires growing, homing cursed flames\n[c/FF3333:UNSTABLE: Fire sometimes swerves unpredictably]\n[c/FF3333:Can damage the caster if too close]\n[c/FF3333:Builds Dark Arts Corruption on use]"
			}
			Howler: {
				DisplayName: Howler
				Tooltip: "'YOUR FATHER AND I ARE ABSOLUTELY DISGUSTED!'\nHoming screaming letter that explodes with confusion"
			}
			ScreechingHowler: {
				DisplayName: Screeching Howler
				Tooltip: "'When a Howler meets a Mandrake, the result is truly deafening'\nUpgraded Howler with massive AoE and higher damage\nCrafted from Howler + Mandrake materials"
			}
			ApparitionCharm: {
				DisplayName: Apparition Charm
				Tooltip: "'Destination, Determination, Deliberation'\n+5% spell damage, +8% movement speed"
			}
			HedwigItem: {
				DisplayName: Owl Treat
				Tooltip: "'Hedwig!'\nSummons a snowy owl light pet"
			}
			ChocolateFrog: {
				DisplayName: Chocolate Frog
				Tooltip: "'Eat up, it'll help. I just got Dumbledore!'\nHeals 100 HP, grants Swiftness and Well Fed"
			}
			BertieBottsBeans: {
				DisplayName: Bertie Bott's Every Flavour Beans
				Tooltip: "'They mean every flavour'\nGrants a random buff... or debuff. Feeling lucky?"
			}
			FizzyWhizbee: {
				DisplayName: Fizzing Whizbee
				Tooltip:
					'''
					Honeydukes levitation sherbet balls
					'Makes you float like a fairy!'
					Grants Featherfall
					'''
			}
			PepperImp: {
				DisplayName: Pepper Imp
				Tooltip:
					'''
					Honeydukes pepper-flavoured sweets
					'Breathe fire for your friends!'
					Grants fire breath attack on hit
					'''
			}
			SugarQuill: {
				DisplayName: Sugar Quill
				Tooltip:
					'''
					Honeydukes sugar-spun writing quill
					'Suck on it in class and look thoughtful!'
					Grants mana regeneration
					'''
			}
			AcidPop: {
				DisplayName: Acid Pop
				Tooltip:
					'''
					Honeydukes acid-flavoured lollipop
					'Burned a hole right through my tongue!'
					Grants Acid Spit ranged attack
					'''
			}
			DrooblesBestBlowingGum: {
				DisplayName: Drooble's Best Blowing Gum
				Tooltip:
					'''
					Honeydukes bluebell-coloured bubblegum
					'Lets you blow bubbles that won't pop for days!'
					Grants a protective bubble shield
					'''
			}
			ElmWand: {
				DisplayName: Elm Wand
				Tooltip: "'Elm favours dignity, precision, and refined magical work'\nCasts Reparo — restores Protego fields, Room buffs, and anti-despair wards\nUtility support, not flesh-healing"
			}
			AlohomoraKey: {
				DisplayName: Alohomora Key
				Tooltip: "'Standard Book of Spells, Chapter Seven'\nCasts Alohomora — the Unlocking Charm\nOpens doors and locks. Does not deal damage.\nThe mod's first true utility spell — Canon Tier A"
			}
			RoomOfRequirementKey: {
				DisplayName: Room of Requirement Key
				Tooltip:
					'''
					'I need a place to...'
					Summons a magical room that adapts to your current need
					The Room detects your state and grants the appropriate buff for 3 minutes
					Cannot be used while a Room buff is active
					'''
			}
			HouseElfBell: {
				DisplayName: House-Elf Bell
				Tooltip: "'Ring for service'\nSummons a House-Elf minion that teleports and attacks enemies"
			}
			Veritaserum: {
				DisplayName: Veritaserum
				Tooltip: "'Three drops and the Dark Lord himself would spill his secrets'\nReveals all enemies, traps, and treasure"
			}
			Amortentia: {
				DisplayName: Amortentia
				Tooltip: "'The most powerful love potion in existence'\nGreatly reduces enemy aggro, grants regen"
