			}
			FireboltMountBuff: {
				DisplayName: Firebolt
				Description: The finest racing broom in existence
			}
			PhoenixMinionBuff: {
				DisplayName: Phoenix Companion
				Description: A phoenix fights by your side and heals your wounds
			}
			NifflerBuff: {
				DisplayName: Niffler
				Description: Increased coin drops from a shiny-seeking companion
			}
			HedwigBuff: {
				DisplayName: Hedwig
				Description: A loyal snowy owl lights your way
			}
			HouseElfMinionBuff: {
				DisplayName: House-Elf
				Description: A loyal house-elf fights at your command
			}
			VeritaserumBuff: {
				DisplayName: Truth Serum
				Description: Nothing can hide from you
			}
			AmortentiaBuff: {
				DisplayName: Love Potion
				Description: Enemies seem less interested in you
			}
			GillyweedBuff: {
				DisplayName: Gillyweed
