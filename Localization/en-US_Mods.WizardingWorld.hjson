			// === PHASE 20 ===
			SpellBook: {
				DisplayName: Standard Book of Spells
				Tooltip:
					'''
					'by Miranda Goshawk'
					An in-game reference guide to all wands and spells
					Use multiple times to browse 5 pages
					Shows wand tiers, damage values, spells, and crafting tips
					Sold by Ollivander. Reusable
					'''
				Guide: {
					OverviewTitle: "=== STANDARD BOOK OF SPELLS ==="
					OverviewAuthor: "by Miranda Goshawk"
					OverviewBrowse: "Use again to browse pages (5 total):"
					OverviewPage1: "  Page 1: Early Wands (Pre-Boss)"
					OverviewPage2: "  Page 2: Mid-Tier Wands (Post-Boss / Hardmode)"
					OverviewPage3: "  Page 3: Late-Game Wands (Post-Mech / Endgame)"
					OverviewPage4: "  Page 4: Utility Spells"
					Page1Title: "=== PAGE 1: EARLY WANDS ==="
					Page1Line1: "Oak Wand [12 dmg] — Stupefy (stun bolt)"
					Page1Line2: "  Recipe: Wood + Fallen Stars @ Workbench"
					Page1Line3: "Willow Wand [16 dmg] — Expelliarmus (knockback bolt)"
					Page1Line4: "  Recipe: Wood + Fallen Stars + Sapphire @ Workbench"
					Page1Line5: "Ash Wand [22 dmg] — Incendio (fire bolt)"
					Page1Line6: "  Recipe: Ash Wood + Hellstone + Ruby @ Enchanting Table"
					Page1Line7: "Holly Wand [28 dmg] — Expelliarmus + Protego shield"
					Page1Line8: "Red Oak Wand [32 dmg] — Riddikulus (anti-Boggart, anti-fear)"
					Page1Line9: "Rowan Wand [30 dmg] — Bombarda (destroys terrain!)"
					Page1Line10: "Birch Wand [28 dmg] — Levicorpus (launches enemies skyward)"
					Page2Title: "=== PAGE 2: MID-TIER WANDS ==="
					Page2Line1: "Phoenix Feather [30 dmg] — Incendio (double shot chance)"
					Page2Line2: "  Requires: Hellstone Bars + Feathers"
					Page2Line3: "Dragon Heartstring [42 dmg] — Sectumsempra (bleed curse)"
					Page2Line4: "Hawthorn [38 dmg] — Chain Stupefy (bounces 4 enemies)"
					Page2Line5: "Blackthorn [35 dmg] — Impedimenta (AoE slow)"
					Page2Line6: "Cypress [30 dmg] — Conjunctivitis (boss debuff tool)"
					Page2Line7: "Unicorn Hair [55 dmg] — Expecto Patronum (homing guardian)"
					Page2Line8: "  Requires: Pearlwood + Unicorn Horn + Souls of Light"
					Page2Line9: "Yew [48 dmg] — Crucio (channeled DoT beam)"
					Page3Title: "=== PAGE 3: LATE-GAME & ENDGAME WANDS ==="
					Page3Line1: "Ebony Wand — Apparition (teleport to cursor!)"
					Page3Line2: "  Requires: Ebonwood + Souls of Light/Night + Essence"
					Page3Line3: "Elder Wand [120 dmg] — Avada Kedavra (killing curse)"
					Page3Line4: "  Drops from: Lord Voldemort"
					Page3Line5: "Fiendfyre Wand [95 dmg] — Growing cursed fire"
					Page3Line6: "  Requires: Hellstone + Souls + Solar Fragments + Essence"
					Page3Line7: "Elder Wand mastery replaces the old Wand of Destiny path"
					Page3Line8: "  Master the Elder Wand through Wand Mastery to earn its legend-title"
					Page3Line9: "  'Wand of Destiny' is now lore flavor, not a separate item"
					Page4Title: "=== PAGE 4: UTILITY SPELLS ==="
					Page4Line1: "Larch Wand — Alternates Finite Incantatem (clear debuffs) + Accio (pull items)"
					Page4Line2: "Cedar Wand — Lumos Maxima (massive light orb, hurts undead)"
					Page4Line3: "Elm Wand — Reparo (repairs wards, Protego fields, and Room buffs)"
					Page4Tip1: "TIP: The Enchanting Table counts as a Workbench too!"
					Page4Tip2: "TIP: Essence of Magic drops from all magical creatures!"
					Page4Tip3: "TIP: Patronus is the real anti-Dementor answer. Use Riddikulus for Boggarts."
				}
			}

