Mods: {
	WizardingWorld: {
		DamageClasses.SpellDamage.DisplayName: spell

		Conditions: {
			DownedBasilisk: After defeating the Basilisk
			DownedAnyMechBoss: After defeating a mechanical boss
			DownedHorntail: After defeating the Hungarian Horntail
			DownedVoldemort: After defeating the Dark Lord
			DownedTroll: After defeating the Mountain Troll
			DownedAragog: After defeating Aragog
			DownedFluffy: After defeating Fluffy
			DownedBellatrix: After defeating Bellatrix Lestrange
			DownedFenrir: After defeating Fenrir Greyback
			DownedDementorKing: After defeating Azkaban's Despair
			DownedQuirrell: After defeating Professor Quirrell
			DownedUmbridge: After defeating Dolores Umbridge
			DownedBartyCrouch: After defeating Barty Crouch Jr
			PostFenrirAndPlantera: After defeating Fenrir Greyback and Plantera
			PostBellatrixAndPlantera: After defeating Bellatrix Lestrange and Plantera
			PostBartyAndGolem: After defeating Barty Crouch Jr and Golem
		}

		ItemMessages: {
			LetterHeader: === HOGWARTS ACCEPTANCE LETTER ===
			LetterDear: Dear {0},
			LetterWelcome: We are pleased to inform you that you have been accepted into the Wizarding World.
			LetterStartHeader: Your first steps:
			LetterStart1: 1. Your Oak Wand casts Stupefy and is ready to use immediately.
			LetterStart2: 2. Craft an Enchanting Table at a Work Bench, or buy one from Ollivander once he moves in.
			LetterStart3: 3. Build housing for Ollivander; he sells starter wands and the Standard Book of Spells.
			LetterStart4: 4. Use the Enchanting Table to craft better wands, potions, gear, and boss summons.
			LetterStart5: 5. Prepare a Smelly Sock at the Enchanting Table to challenge the Mountain Troll.
			LetterWorldHeader: Out in the world:
			LetterWorld1: A Wizard Tower may hold starter loot for a young witch or wizard.
			LetterWorld2: Hogsmeade lies far from spawn and rewards exploration.
			LetterWorld3: The Forbidden Forest grows more dangerous as your story advances.
			LetterWorld4: Dark magic is powerful, but corruption has a cost.
			LetterWorld5: Destroy Horcruxes before facing Voldemort; each one weakens him.
			LetterClosing: Welcome to Hogwarts. Mischief managed, eventually.
			DAGalleonUse: The D.A. Galleon grows warm in your palm.
			SkivingSnackboxUse: You nibble the snackbox. Mischief, managed nutritionally.
		}

		Items: {
			HollyWand: {
				DisplayName: Holly Wand
