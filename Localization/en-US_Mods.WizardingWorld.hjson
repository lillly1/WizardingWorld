		Buffs: {
			ForestWisdomBuff: {
				DisplayName: Forest Wisdom
				Description: "The forest shares its ancient knowledge. +6% damage, danger sense, night vision, +4 life regen."
			}
			SafehouseResolveBuff: {
				DisplayName: Safehouse Resolve
				Description: "The Order's safehouse strengthens your resolve. +6 defense, +4 life regen, Jinxed immunity, -100 aggro."
			}
			TriageResolvedBuff: {
				DisplayName: Triage Resolved
				Description: "St Mungo's treatment stabilized. +8 life regen, +5 defense, venom immunity."
			}
