			}
			ResurrectionPotion: {
				DisplayName: 復活藥水
				Tooltip: "'從灰燼中重生'\n阻止一次死亡：如果你即將死亡，改為恢復到50%\n增益持續10分鐘，觸發一次"
			}
			ShieldCharmPotion: {
				DisplayName: 護盾咒藥水
				Tooltip: "'瓶裝破心護'\n+10防禦，+8%傷害減免持續5分鐘"
			}
			EnchantedMirror: {
				DisplayName: 魔法手鏡
				Tooltip: "'雖然不是乖意若思鏡，但能帶你回家'\n+3%咒語傷害被動加成\n由魔鏡+精華製作"
			}
			DraconisElixir: {
				DisplayName: 龍血靈藥
				Tooltip: "'龍血有十二種用途——這瓶藥水將它們全部發揮'\n獲得憤怒+狂暴+火焰免疫+煉獄光環持續4分鐘\n終極龍力戰鬥藥水"
			}
			JobberknollFeather: {
				DisplayName: 嘰喳鳥羽毛
				Tooltip: "'包含那隻鳥聽過的每一個聲音的回響'\n吐真劑的關鍵材料\n由嘰喳鳥掉落"
			}
			BeastHuntersCharm: {
				DisplayName: 獵獸者護符
				Tooltip:
					'''
					'紐特·乖斯卡曼德會驚恐不已。乖乖乖查理·衛斯理會表示認同。'
					需要龍鱗+三頭犬牙+狼人毛皮——三種野獸的擊殺
					+12%全部傷害，免疫流血+破損護甲
					偵測附近所有生物
					'''
			}
			ImpFlame: {
				DisplayName: 小惡魔之焰
				Tooltip: "'一顆活著的小小火焰'\n消耗獲得30秒煉獄光環\n火焰藥水的製作材料\n由魔法小惡魔掉落"
			}
			DugbogHide: {
				DisplayName: 水潛獸皮
				Tooltip: "'堅韌如樹皮，與環境融為一體'\n隱匿物品的製作材料\n由水潛獸掉落"
			}
			CamouflageCloak: {
				DisplayName: 迷彩斗篷
				Tooltip: "'幾乎和隱形斗篷一樣好。幾乎。'\n-400仇恨值，+10%速度\n靜止不動時變為隱形\n由水潛獸皮+隱形獸毛髮製作"
			}
			FenrirsWolfsbane: {
				DisplayName: 芬沃的狼毒
				Tooltip: "'由狼王本身的精華釀造'\n升級版狼毒——夜間加成大幅增強\n夜間：+25%近戰，+25%速度，+15防禦，+10%暴擊"
			}
			StealthDraught: {
				DisplayName: 隱匿魔藥
				Tooltip: "'像水潛獸融入枯木一樣融入陰影'\n隱形，-500仇恨值，+15%速度持續4分鐘\n由水潛獸皮+隱形獸毛髮釀造"
			}
			SpectralEssence: {
				DisplayName: 幽靈精華
				Tooltip:
					'''
					'從騎士墜信標中採集的月光殘留物'
					製作材料
					'''
			}

			// === 地標可放置物品 ===
			HousePointHourglassItem: {
