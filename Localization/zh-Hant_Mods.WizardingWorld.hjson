			}
			Amortentia: {
				DisplayName: 愛情魔藥
				Tooltip: "'現存最強大的愛情魔藥'\n大幅降低敵人仇恨值，獲得再生"
			}
			HawthornWand: {
				DisplayName: 山楂木魔杖
				Tooltip: "'彈性適中，獨角獸毛杖芯'\n施放連鎖昏昏倒地——昏迷彈在最多4個敵人之間彈射"
