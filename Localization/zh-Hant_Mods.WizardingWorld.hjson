			}
			MoodysEye: {
				DisplayName: 乖乖穆地的魔眼
				Tooltip: "'時刻保持警覺！'\n顯示所有敵人、寶藏、陷阱、電線\n夜視+危險感知+5%傷害\n魔眼能看見一切"
			}
			DragonScaleRing: {
